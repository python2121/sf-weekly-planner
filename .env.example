# Long-lived OAuth token from `claude setup-token` on your laptop.
CLAUDE_CODE_OAUTH_TOKEN=

# Host path where event markdown files live. Bind-mounted into both containers.
EVENTS_VOLUME=/volume1/Andrew/Code and Tools/sf_event_data

# Daily run time inside the runner container (HH:MM, 24h).
RUN_TIME=10:30

# Timezone for the runner's schedule and the web app.
TZ=America/Los_Angeles

# Host port the web UI + API listen on.
WEB_PORT=7878

# UID/GID the container runs as. Must match the OWNER of EVENTS_VOLUME on the
# host so the container can write event files. Find with `id -u` / `id -g` as
# the user that owns the events directory (NOT under sudo). Defaults to 1000.
APP_UID=1000
APP_GID=1000
